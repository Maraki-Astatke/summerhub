generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                 @id @default(autoincrement())
  email             String              @unique
  password          String
  phone             String?             @unique
  isVerified        Boolean             @default(false)
  isActive          Boolean             @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  quizResults       QuizResult[]
  
  profile           Profile?
  roles             UserRole[]
  emailVerifications EmailVerification[]
  passwordResets    PasswordReset[]
  userHobbies       UserHobby[]
  lessons           Lesson[]             @relation("TeacherLessons")
  lessonRegistrations LessonRegistration[]
  cartItems         CartItem[]
  certificateTemplates CertificateTemplate[]
  orders            Order[]
  blogPosts         BlogPost[]
  blogComments      BlogComment[]
  blogLikes         BlogLike[]
  eventRegistrations EventRegistration[]
  scholarshipApplications ScholarshipApplication[]
  productReviews    ProductReview[]
  sentMessages      Message[]           @relation("SentMessages")
  receivedMessages  Message[]           @relation("ReceivedMessages")
  productsSold      Product[]            @relation("SellerProducts")
  quizAnswers       QuizAnswer[]
  receivedRecommendations StudentRecommendation[] @relation("StudentRecommendations")
  givenRecommendations   StudentRecommendation[] @relation("AdminRecommendations")
  sentResources      Resource[] @relation("SentResources")
  receivedResources  Resource[] @relation("ReceivedResources")
  studentCertificates      Certificate[] @relation("StudentCertificates")
  teacherCertificates      Certificate[] @relation("TeacherCertificates")
  
  eventPosts        EventPost[]         @relation("EventPostAuthor")
  eventPostComments EventPostComment[]
  eventPostLikes    EventPostLike[]
  talentEventRegistrations TalentEventRegistration[]

  postedJobs            Job[]                 @relation("PostedJobs")
  jobApplications       JobApplication[]      @relation("JobApplications")
  eventSponsorships     EventSponsorship[]    @relation("EventSponsorships")

  parentRelations       ParentChild[]         @relation("ParentRelation")
  childRelations        ParentChild[]         @relation("ChildRelation")
}

model Profile {
  id         Int     @id @default(autoincrement())
  userId     Int     @unique
  user       User    @relation(fields: [userId], references: [id])
  firstName  String?
  lastName   String?
  nationalId String? @unique
  age        Int?
  grade      String?
  city       String?
  schoolName String?
  bio        String?
  profession String?
  company    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Role {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  description       String?
  createdAt         DateTime @default(now())
  
  users             UserRole[]
}

model UserRole {
  id                Int      @id @default(autoincrement())
  userId            Int
  roleId            Int
  assignedAt        DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role              Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  @@unique([userId, roleId])
}

model EmailVerification {
  id                Int      @id @default(autoincrement())
  userId            Int
  code              String
  expiresAt         DateTime
  used              Boolean  @default(false)
  createdAt         DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id                Int      @id @default(autoincrement())
  userId            Int
  code              String
  expiresAt         DateTime
  used              Boolean  @default(false)
  createdAt         DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginAttempt {
  id                Int      @id @default(autoincrement())
  email             String
  ipAddress         String?
  success           Boolean  @default(false)
  attemptedAt       DateTime @default(now())
}

model Hobby {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  description       String?
  ageGroup          String?
  imageUrl          String?
  categoryId        Int?
  createdAt         DateTime @default(now())
  quizQuestions     QuizQuestion[]
  category          HobbyCategory? @relation(fields: [categoryId], references: [id])
  certificateTemplates     CertificateTemplate[] 
  userHobbies       UserHobby[]
  lessons           Lesson[]
  recommendations   StudentRecommendation[]
}

model HobbyCategory {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  description       String?
  
  hobbies           Hobby[]
}

model UserHobby {
  id                Int      @id @default(autoincrement())
  userId            Int
  hobbyId           Int
  interestLevel     Int?
  createdAt         DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hobby             Hobby    @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
  
  @@unique([userId, hobbyId])
}

model Lesson {
  id                Int      @id @default(autoincrement())
  title             String
  description       String?
  teacherId         Int
  hobbyId           Int
  dateTime          DateTime
  durationMinutes   Int      @default(60)
  maxStudents       Int      @default(20)
  zoomLink          String?
  recordingUrl      String?
  createdAt         DateTime @default(now())
  
  teacher           User     @relation("TeacherLessons", fields: [teacherId], references: [id])
  hobby             Hobby    @relation(fields: [hobbyId], references: [id])
  registrations     LessonRegistration[]
  resources         Resource[] 
}

model LessonRegistration {
  id                Int      @id @default(autoincrement())
  lessonId          Int
  studentId         Int
  registeredAt      DateTime @default(now())
  attended          Boolean  @default(false)
  
  lesson            Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student           User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([lessonId, studentId])
}

model Product {
  id                Int             @id @default(autoincrement())
  name              String
  description       String?
  price             Float
  stockCount        Int             @default(0)
  imageUrl          String?
  phone             String?
  categoryId        Int?
  sellerId          Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  category          ProductCategory? @relation(fields: [categoryId], references: [id])
  seller            User?           @relation("SellerProducts", fields: [sellerId], references: [id])
  cartItems         CartItem[]
  orderItems        OrderItem[]
  reviews           ProductReview[]
}

model ProductCategory {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  description       String?
  
  products          Product[]
}

model CartItem {
  id                Int      @id @default(autoincrement())
  userId            Int
  productId         Int
  quantity          Int      @default(1)
  addedAt           DateTime @default(now())
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  @@unique([userId, productId])
}

model Order {
  id                Int         @id @default(autoincrement())
  userId            Int
  totalAmount       Float
  status            String      @default("pending")
  paymentMethod     String?
  paymentId         String?
  shippingAddress   String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  user              User        @relation(fields: [userId], references: [id])
  items             OrderItem[]
}

model OrderItem {
  id                Int      @id @default(autoincrement())
  orderId           Int
  productId         Int
  quantity          Int
  priceAtTime       Float
  
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product  @relation(fields: [productId], references: [id])
}

model ProductReview {
  id                Int      @id @default(autoincrement())
  productId         Int
  userId            Int
  rating            Int
  comment           String?
  createdAt         DateTime @default(now())
  
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([productId, userId])
}

model BlogPost {
  id                Int          @id @default(autoincrement())
  title             String
  content           String
  authorId          Int
  imageUrl          String?
  publishedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  author            User         @relation(fields: [authorId], references: [id])
  comments          BlogComment[]
  likes             BlogLike[]
}

model BlogComment {
  id                Int      @id @default(autoincrement())
  postId            Int
  userId            Int
  content           String
  createdAt         DateTime @default(now())
  
  post              BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id])
}

model BlogLike {
  id                Int      @id @default(autoincrement())
  postId            Int
  userId            Int
  createdAt         DateTime @default(now())
  
  post              BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id])
  
  @@unique([postId, userId])
}

model Event {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  date              DateTime
  prize             String?
  maxParticipants   Int      @default(50)
  imageUrl          String?
  createdAt         DateTime @default(now())
  
  registrations     EventRegistration[]
}

model EventRegistration {
  id                Int      @id @default(autoincrement())
  eventId           Int
  userId            Int
  performanceLink   String?
  registeredAt      DateTime @default(now())
  
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user              User     @relation(fields: [userId], references: [id])
  
  @@unique([eventId, userId])
}

model Scholarship {
  id                Int      @id @default(autoincrement())
  name              String
  description       String?
  amount            Float
  requirements      String?
  deadline          DateTime
  createdAt         DateTime @default(now())
  
  applications      ScholarshipApplication[]
}

model ScholarshipApplication {
  id                Int      @id @default(autoincrement())
  scholarshipId     Int
  userId            Int
  essayText         String?
  status            String   @default("pending")
  appliedAt         DateTime @default(now())
  
  scholarship       Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  user              User        @relation(fields: [userId], references: [id])
  
  @@unique([scholarshipId, userId])
}

model Message {
  id                Int      @id @default(autoincrement())
  senderId          Int
  receiverId        Int
  content           String
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())
  
  sender            User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver          User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

model QuizQuestion {
  id                Int           @id @default(autoincrement())
  question          String
  options           Json
  hobbyId           Int?
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  hobby             Hobby?        @relation(fields: [hobbyId], references: [id])
  results           QuizResult[]
  answers           QuizAnswer[]
}

model QuizResult {
  id                Int           @id @default(autoincrement())
  userId            Int
  quizQuestionId    Int?
  answers           Json
  topHobbyIds       Int[]
  completedAt       DateTime      @default(now())
  
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizQuestion      QuizQuestion? @relation(fields: [quizQuestionId], references: [id])
}

model QuizAnswer {
  id                Int      @id @default(autoincrement())
  studentId         Int
  questionId        Int
  selectedHobbyId   Int      @default(0)
  answerText        String?
  createdAt         DateTime @default(now())
  
  student           User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  question          QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  @@unique([studentId, questionId])
}

model StudentRecommendation {
  id                Int      @id @default(autoincrement())
  studentId         Int
  adminId           Int
  hobbyId           Int
  reason            String?
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())
  
  student           User     @relation("StudentRecommendations", fields: [studentId], references: [id], onDelete: Cascade)
  admin             User     @relation("AdminRecommendations", fields: [adminId], references: [id], onDelete: Cascade)
  hobby             Hobby    @relation(fields: [hobbyId], references: [id], onDelete: Cascade)
}

model CertificateTemplate {
  id            Int           @id @default(autoincrement())
  title         String
  description   String?
  templateHtml  String
  hobbyId       Int?
  teacherId     Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  hobby         Hobby?        @relation(fields: [hobbyId], references: [id])
  teacher       User          @relation(fields: [teacherId], references: [id])
  certificates  Certificate[]
}

model Certificate {
  id              Int           @id @default(autoincrement())
  studentId       Int?
  templateId      Int?
  teacherId       Int?
  issuedAt        DateTime      @default(now())
  certificateHtml String
  customMessage   String?
  
  student         User?         @relation("StudentCertificates", fields: [studentId], references: [id])
  teacher         User?         @relation("TeacherCertificates", fields: [teacherId], references: [id])
  template        CertificateTemplate? @relation(fields: [templateId], references: [id])
}

model Resource {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  fileName    String?
  fileUrl     String?
  fileType    String?
  fileSize    Int?
  senderId    Int
  receiverId  Int?
  lessonId    Int?
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  
  sender      User      @relation("SentResources", fields: [senderId], references: [id])
  receiver    User?     @relation("ReceivedResources", fields: [receiverId], references: [id])
  lesson      Lesson?   @relation(fields: [lessonId], references: [id])
}

model EventPost {
  id                Int      @id @default(autoincrement())
  title             String
  date              String
  time              String
  location          String
  about             String
  whoCanJoin        String
  howToRegister     String
  contact           String
  imageUrl          String?
  registrationOpen  Boolean  @default(false)
  authorId          Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  author            User     @relation("EventPostAuthor", fields: [authorId], references: [id])
  comments          EventPostComment[]
  likes             EventPostLike[]
  registrations     TalentEventRegistration[]
  sponsorships      EventSponsorship[]
}

model EventPostComment {
  id                Int      @id @default(autoincrement())
  postId            Int
  userId            Int
  content           String
  createdAt         DateTime @default(now())
  
  post              EventPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventPostLike {
  id                Int      @id @default(autoincrement())
  postId            Int
  userId            Int
  createdAt         DateTime @default(now())
  
  post              EventPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([postId, userId])
}

model TalentEventRegistration {
  id          Int      @id @default(autoincrement())
  postId      Int
  userId      Int?
  name        String
  phone       String
  email       String
  description String?
  fileUrl     String?
  fileName    String?
  createdAt   DateTime @default(now())
  
  post        EventPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Job {
  id                  Int              @id @default(autoincrement())
  title               String
  description         String
  hobbyCategory       String
  jobType             String
  location            String
  payment             Float
  paymentType         String
  requirements        String?
  experienceLevel     String           @default("any")
  positionsAvailable  Int              @default(1)
  applicationDeadline DateTime
  status              String           @default("pending") // pending, approved, rejected
  rejectionReason     String?
  giverId             Int
  giver               User             @relation("PostedJobs", fields: [giverId], references: [id], onDelete: Cascade)
  applications        JobApplication[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model JobApplication {
  id          Int      @id @default(autoincrement())
  jobId       Int
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  studentId   Int
  student     User     @relation("JobApplications", fields: [studentId], references: [id], onDelete: Cascade)
  fullName    String?
  email       String?
  phone       String?
  description String?
  cvUrl       String?
  cvName      String?
  status      String   @default("pending") // pending, shortlisted, hired, rejected
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobId, studentId])
}

model EventSponsorship {
  id              Int      @id @default(autoincrement())
  eventId         Int
  event           EventPost @relation(fields: [eventId], references: [id], onDelete: Cascade)
  giverId         Int
  giver           User     @relation("EventSponsorships", fields: [giverId], references: [id], onDelete: Cascade)
  amount          Float
  sponsorType     String   @default("financial")
  message         String?
  status          String   @default("pending") // pending, approved, rejected
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([eventId, giverId])
}

model ParentChild {
  id        Int      @id @default(autoincrement())
  parentId  Int
  childId   Int
  createdAt DateTime @default(now())

  parent    User     @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)
  child     User     @relation("ChildRelation", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
}